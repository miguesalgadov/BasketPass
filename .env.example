# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3002

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# PostgreSQL
DATABASE_URL=postgresql://dev:dev123@localhost:5432/basketpass

# Redis
REDIS_URL=redis://localhost:6379

# MercadoPago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_PUBLIC_KEY=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@basketpass.app
SENDGRID_FROM_NAME=BasketPass

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Storage (Cloudflare R2 / AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=basketpass-files
S3_PUBLIC_URL=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
